  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, proximity_score, created_at\n        FROM proofs\n        WHERE customer_id = $1\n          AND (\n            $2::TIMESTAMPTZ IS NULL\n            OR (created_at, id) < ($2::TIMESTAMPTZ, $3::UUID)\n          )\n        ORDER BY created_at DESC, id DESC\n        LIMIT $4\n        ",
